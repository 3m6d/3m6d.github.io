---
interface Props {
  slug: string;
  title: string;
  summary: string;
  stack: string[];
  period?: string;
  repoUrl?: string;
  demoUrl?: string;
}

const { slug, title, summary, stack, period, repoUrl, demoUrl } = Astro.props;
---

<article class="card project-card">
  <div class="head">
    <h3><a href={`/projects/${slug}/`}>{title}</a></h3>
    {period ? <p class="period mono">{period}</p> : null}
  </div>
  <p class="summary">{summary}</p>
  {
    stack.length > 0 && (
      <ul class="tag-list">
        {stack.map((tech) => (
          <li class="tag">{tech}</li>
        ))}
      </ul>
    )
  }
  <div class="links">
    <a href={`/projects/${slug}/`}>Read more →</a>
    {repoUrl ? (
      <a href={repoUrl} target="_blank" rel="noopener noreferrer">
        Repo ↗
      </a>
    ) : null}
    {demoUrl ? (
      <a href={demoUrl} target="_blank" rel="noopener noreferrer">
        Demo ↗
      </a>
    ) : null}
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  h3 {
    font-size: 1.1rem;
    margin: 0;
  }

  h3 a {
    color: var(--text);
    text-decoration: none;
  }

  h3 a:hover,
  h3 a:focus-visible {
    color: var(--accent);
  }

  .period {
    color: var(--text-faint);
    font-size: 0.78rem;
    white-space: nowrap;
  }

  .summary {
    margin: 0;
  }

  .links {
    display: flex;
    gap: 1.25rem;
    font-size: 0.88rem;
  }
</style>
